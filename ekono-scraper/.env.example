# Base store URL (no trailing slash)
BASE_URL=https://www.tiendasekono.com

# Sitemap entry point used for product discovery (defaults to BASE_URL/sitemap.xml)
# SITEMAP_URL=https://www.tiendasekono.com/sitemap.xml

# SQLite file location
DB_PATH=./data/ekono.sqlite

# Polite crawling
CONCURRENCY=3
REQUEST_DELAY_MS=250
REQUEST_TIMEOUT_MS=20000
MAX_RETRIES=4

# Identify the bot honestly; include a contact so the site owner can reach you
USER_AGENT=ekono-price-bot/0.1 (+https://github.com/your-org/ekono-scraper)
