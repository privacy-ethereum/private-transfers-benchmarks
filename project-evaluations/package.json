{
  "name": "project-evaluations",
  "version": "1.0.0",
  "description": "Evaluation UI for private transfer protocols",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "research": "tsx scripts/research.ts",
    "lint:evaluations": "tsx scripts/utils/lint-evaluations.ts",
    "generate:markdown-report": "tsx report/1_generate-markdown-report.ts && prettier --write ./report/report.md",
    "generate:pdf-report": "tsx report/2_convert-markdown-to-pdf-report.ts",
    "update-report": "pnpm generate:markdown-report && pnpm generate:pdf-report"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "marked": "^18.0.3",
    "puppeteer-core": "^25.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.1",
    "dotenv": "^17.3.1",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.5"
  }
}
